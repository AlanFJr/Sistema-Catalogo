generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Catalog {
  id           String        @id @default(uuid())
  name         String
  description  String?
  status       String        @default("in_progress")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  catalogItems CatalogItem[]
}

model Card {
  id          String        @id @default(uuid())
  refCode     String        @unique
  title       String
  description String?
  tags        String?
  dimensions  String?
  weight      String?
  boxQty      String?
  price       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  images      Image[]
  catalogItems CatalogItem[]
}

model Image {
  id        String   @id @default(uuid())
  cardId    String
  filePath  String
  mimeType  String
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model CatalogItem {
  id           String   @id @default(uuid())
  catalogId    String
  itemType     String
  cardId       String?
  spacerConfig String?
  position     Int      @default(0)
  createdAt    DateTime @default(now())

  catalog Catalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  card    Card?   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([catalogId, position])
  @@index([cardId])
}
